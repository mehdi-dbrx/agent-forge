# Copy this file to .env.local and fill in your values.
# cp .env.example .env.local

# ── Databricks Auth ────────────────────────────────────────────────────────────
# Use either profile-based auth OR host+token (not both).

# Profile name from ~/.databrickscfg (e.g. DEFAULT, my-workspace)
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Direct host + token (takes precedence over profile when both are set)
# DATABRICKS_HOST=https://my-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SQL warehouse ID for Unity Catalog queries (e.g. 8ba51d8cad2a3d9a)
DATABRICKS_WAREHOUSE_ID=

# ── Unity Catalog ─────────────────────────────────────────────────────────────
# catalog.schema where project tables and functions are created (e.g. my_catalog.my_schema)
PROJECT_UNITY_CATALOG_SCHEMA=

# ── Agent Model ───────────────────────────────────────────────────────────────
# Foundation model endpoint name (e.g. databricks-claude-sonnet-4-6)
# or full invocations URL for cross-workspace (e.g. https://other-ws.cloud.databricks.com/serving-endpoints/my-model/invocations)
AGENT_MODEL_ENDPOINT=

# Token for the workspace hosting AGENT_MODEL_ENDPOINT — only needed for cross-workspace / full URL
# AGENT_MODEL_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Databricks App ────────────────────────────────────────────────────────────
# App name for Databricks Apps deployment (e.g. my-agent-app)
DBX_APP_NAME=

# Local proxy target — leave as-is for local dev
API_PROXY=http://localhost:8000/invocations

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=databricks
MLFLOW_REGISTRY_URI=databricks-uc

# Set by create_mlflow_experiment.py or create_all_assets.py (e.g. 3688767017703470)
MLFLOW_EXPERIMENT_ID=

# ── Genie ─────────────────────────────────────────────────────────────────────
# Set by create_genie_space.py or create_all_assets.py (e.g. 01f0000000000000000000000000000a)
PROJECT_GENIE_CHECKIN=

# ── Knowledge Assistants ──────────────────────────────────────────────────────
# Endpoint name for each KA — set after deploying via forge-add-ka (e.g. ka-xxxxxxxx-endpoint)
PROJECT_KA_PASSENGERS=
